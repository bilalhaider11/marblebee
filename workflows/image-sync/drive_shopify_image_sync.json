    {
      "parameters": {
        "jsCode": "const SHEETS = [\n  'Animal','Bench','Planter','Fountain','Lamppost','Bathtub','Sink','Vanity',\n  'Fireplace','Table','Statue','MarbleSlab','2026Instock','DoorSurround',\n  'Wall-Coverings','Exterior-Wall-Decoration','MarbleRangeHood','Moulding','StoneMosaicTile','MarbleMedallion'\n];\n// Clear any leftover data from a previous run\nconst sd = $getWorkflowStaticData('global');\nsd.allProducts = [];\nreturn SHEETS.map(s => ({ json: { sheet_name: s } }));"
      },
      "id": "662819e2-ce7d-44b0-9f4b-0e90374b2bbc",
