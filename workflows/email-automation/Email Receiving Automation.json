      "parameters": {
        "jsCode": "// ----------------------------------------\n// HTML entity decoder\n// ----------------------------------------\nfunction decodeHtml(str) {\n  if (!str) return str;\n\n  let decoded = str;\n  for (let i = 0; i < 2; i++) {\n    decoded = decoded\n      .replace(/&amp;/g, '&')\n      .replace(/&lt;/g, '<')\n      .replace(/&gt;/g, '>')\n      .replace(/&quot;/g, '\"')\n      .replace(/&apos;/g, \"'\")\n      .replace(/&#(\\d+);/g, (_, dec) =>\n        String.fromCharCode(dec)\n      )\n      .replace(/&#x([0-9a-fA-F]+);/g, (_, hex) =>\n        String.fromCharCode(parseInt(hex, 16))\n      );\n  }\n  return decoded;\n}\n\nfunction extractEmail(str) {\n  if (!str) return '';\n  const match = str.match(/<(.+?)>/);\n  return (match ? match[1] : str).trim().toLowerCase();\n}\n\nconst items = $input.all();\n\nconst NOT_INTERESTED_REGEX =\n  /\\b(no|not|not interested|not looking|not required|not needed|delivery failed|permanent error)\\b/i;\n\nconst AUTO_DISQUALIFY_REGEX =\n  /(postmaster|daemon|info|admin|webmaster|mailer-daemon|no-?reply)/i;\n\nconst latestPerThread = {};\n\nfor (const { json: thread } of items) {\n\n  let sentMessage = null;\n  let latestReply = null;\n\n  for (const msg of thread.messages || []) {\n    const labels = msg.labels || [];\n    const isSent = labels.some(l => l.id === 'SENT');\n    if (isSent) { sentMessage = msg; continue; }\n    if (!latestReply || Number(msg.internalDate) > Number(latestReply.internalDate)) {\n      latestReply = msg;\n    }\n  }\n\n  if (!latestReply) continue;\n\n  const { snippet = '', From = '', Subject = '', threadId, internalDate } = latestReply;\n\n  let from_email = '';\n  let to_email = '';\n\n  if (sentMessage) {\n    const originalFrom = extractEmail(sentMessage.From);\n    const originalTo = extractEmail(sentMessage.To);\n    const failedRecipient = latestReply[\"X-Failed-Recipients\"];\n    from_email = (failedRecipient || originalTo).toLowerCase();\n    to_email = originalFrom;\n  }\n\n  const date = new Date(Number(internalDate));\n  const reply_time = date.toLocaleString(\"en-US\", { timeZone: \"America/New_York\" });\n\n  let actual_reply = snippet.match(/^(.*?)(?:On\\s.+?wrote:)/is)?.[1] || snippet;\n  actual_reply = decodeHtml(actual_reply).replace(/-{2,}.*$/s, '').replace(/\\n{3,}/g, '\\n\\n').trim();\n\n  const isDefaultNegative = NOT_INTERESTED_REGEX.test(actual_reply);\n  const isAutoSender = AUTO_DISQUALIFY_REGEX.test(extractEmail(From));\n  const interested = !(isDefaultNegative || isAutoSender);\n\n  if (latestPerThread[threadId] && Number(latestPerThread[threadId].internalDate) >= Number(internalDate)) {\n    continue;\n  }\n\n  latestPerThread[threadId] = {\n    from_name: '', from_email, to: to_email, subject: Subject,\n    actual_reply, interested, thread_id: threadId, reply_time, internalDate\n  };\n}\n\nreturn Object.values(latestPerThread).map(r => ({\n  json: {\n    from_name: r.from_name, from_email: r.from_email, to: r.to,\n    subject: r.subject, actual_reply: r.actual_reply, interested: r.interested,\n    thread_id: r.thread_id, reply_time: r.reply_time\n  }\n}));"
      },
