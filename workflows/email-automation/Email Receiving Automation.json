    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst replyItems = $items(\"Parse Incoming Reply\");\n\nconst replyMap = new Map();\nfor (const item of replyItems) {\n  const r = item.json;\n  const key = (r.from_email || \"\").toLowerCase();\n  if (!replyMap.has(key)) { replyMap.set(key, r); }\n}\n\nconst seen = new Set();\nconst output = [];\n\nfor (const item of inputItems) {\n  const user = item.json;\n  const email = (user.email || \"\").toLowerCase();\n  if (seen.has(email)) continue;\n  const reply = replyMap.get(email);\n  if (!reply) continue;\n  seen.add(email);\n  output.push({\n    json: {\n      row_number: user.row_number, email: user.email, name: user.name,\n      last_sent_date: user.last_sent_date, templates_sent: user.templates_sent,\n      workspace_used: user.workspace_used, thread_id: user.thread_id, msg_id: user.msg_id,\n      from_email: reply.from_email, to: reply.to, subject: reply.subject,\n      actual_reply: reply.actual_reply, interested: reply.interested, reply_time: reply.reply_time\n    }\n  });\n}\n\nreturn output;"
      },
