      "id": "53d6bb94-495b-476f-99d5-3f8e74762f52",
      "name": "Outlook | Fetch Message + Attachments",
      "webhookId": "c1c331d7-f9bd-4045-b252-f530d984d7e9",
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "Pg1Yh9oUPVFueUUr",
          "name": "Axe_AI-outlook"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst data = $('Loop | Outlook Message IDs');\nconst sheet_id = data.item.json.sheet_id;\n// logged-in mailbox email\nconst MY_EMAIL = 'jack@marblebee.com'.toLowerCase();\n\n/**\n * Cut message at polite sign-offs like \"Kind regards,\"\n */\nfunction cutAtKindRegards(text = '') {\n  const match = text.match(\n    /\\b(Kind regards|Best regards|Regards|Warm regards),\\b/i\n  );\n  return match ? text.slice(0, match.index).trim() : text.trim();\n}\n\n/**\n * Extract latest message from Outlook/Gmail HTML body\n */\nfunction extractLatestMessageFromHtml(html = '') {\n  if (!html) return '';\n\n  // 1ï¸â£ Remove scripts & styles\n  html = html\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, '');\n\n  // 2ï¸â£ Cut at known reply/forward separators (earliest match wins)\n  const cutPatterns = [\n    /<hr[\\s\\S]*?>/i,\n    /<div[^>]+id=[\"']divRplyFwdMsg[\"'][\\s\\S]*?>/i,\n    /<div[^>]+class=[\"'][^\"']*gmail_quote[^\"']*[\"'][\\s\\S]*?>/i,\n    /\\nOn\\s+(Mon|Tue|Wed|Thu|Fri|Sat|Sun),\\s+[A-Za-z]{3}\\s+\\d{1,2},\\s+\\d{4},/i\n  ];\n\n  for (const pattern of cutPatterns) {\n    const match = html.match(pattern);\n    if (match) {\n      html = html.slice(0, match.index);\n    }\n  }\n\n  // 3ï¸â£ Strip remaining HTML â plain text\n  return html\n    .replace(/<\\/?[^>]+>/g, '')\n    .replace(/&nbsp;/gi, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\n\nfunction cutAtReplyDate(text = '') {\n  const replyRegex =\n    /\\nOn\\s+(Mon|Tue|Wed|Thu|Fri|Sat|Sun),\\s+[A-Za-z]{3}\\s+\\d{1,2},\\s+\\d{4},\\s+\\d{1,2}:\\d{2}\\s*(AM|PM)/i;\n\n  const match = text.match(replyRegex);\n  return match ? text.slice(0, match.index).trim() : text.trim();\n}\n\n/**\n * Strip HTML safely\n */\nfunction stripHtml(html = '') {\n  return html\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<\\/?[^>]+(>|$)/g, '')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\n/**\n * Cut text at first occurrence of:\n *  - 5 or more underscores\n *  - \"Get Outlook for \"\n * whichever comes first\n */\nfunction cutAtSeparator(text = '') {\n  const match = text.match(/_{5,}|Get Outlook for /i);\n  return match ? text.slice(0, match.index).trim() : text.trim();\n}\n\nreturn items.map((item, index) => {\n  const msg = item.json;\n\n  // sender\n  const fromEmail =\n    msg.from?.emailAddress?.address || null;\n\n  // receivers\n  const toEmail =\n    (msg.toRecipients || []).map(\n      r => r.emailAddress?.address\n    );\n\n  // sent or received\n  const direction =\n    fromEmail?.toLowerCase() === MY_EMAIL\n      ? 'sent'\n      : 'received';\n\n  // body (HTML â text)\nlet message = '';\n\nif (msg.body?.contentType === 'html') {\n  message = extractLatestMessageFromHtml(msg.body.content);\n} else {\n  message = stripHtml(msg.body?.content || '');\n}\n\n// 1ï¸â£ Remove signatures / Outlook footer\nmessage = cutAtSeparator(message);\n\n// 2ï¸â£ Remove quoted reply thread\nmessage = cutAtReplyDate(message);\n\n// 3ï¸â£ Remove content after \"Kind regards,\"\nmessage = cutAtKindRegards(message);\n\n\n  return {\n    json: {\n      sheet_id,\n      message,\n      fromEmail,\n      toEmail,\n      direction,\n      timestamp:\n        msg.sentDateTime || msg.receivedDateTime,\n      subject: msg.subject || null,\n      hasAttachments: msg.hasAttachments || false,\n      row_number:\n        data.first().json.row_number\n    },\n\n    binary: $input.all()[index]?.binary || {}\n  };\n});"
      },
