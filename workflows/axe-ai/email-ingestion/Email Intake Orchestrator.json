      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  let googleQuery = '';\n  let outlookQuery = '';\n  item.json.Email.split(',').forEach((email, i) => {\n    googleQuery += i !== 0 ? ' OR ' : ''\n    googleQuery += `from:${email} OR to:${ email }`\n\n    outlookQuery += i !== 0 ? ' OR ' : ''\n    outlookQuery += `${email}`\n  })\n  item.json.googleQuery = googleQuery;\n  item.json.outlookQuery = outlookQuery;\n}\n\nreturn $input.all();"
      },
