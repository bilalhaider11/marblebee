      "id": "544d9eb5-5dbd-4a97-ad37-6a04577b1523",
      "name": "Outlook | Fetch Message + Attachments",
      "webhookId": "c1c331d7-f9bd-4045-b252-f530d984d7e9",
      "credentials": {
        "microsoftOutlookOAuth2Api": {
          "id": "Pg1Yh9oUPVFueUUr",
          "name": "Axe_AI-outlook"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst sheet_id = $('Loop | Outlook Message IDs').item.json.sheet_id;\n// logged-in mailbox email (important for sent/received detection)\nconst MY_EMAIL = 'celestials070070@outlook.com'.toLowerCase();\n\n// helper to strip HTML safely\nfunction stripHtml(html = '') {\n  return html\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<\\/?[^>]+(>|$)/g, '')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nreturn items.map((item, index) => {\n  const msg = item.json;\n\n  // sender\n  const senderEmail =\n    msg.from?.emailAddress?.address || null;\n\n  // receivers\n  const receiverEmails =\n    (msg.toRecipients || []).map(\n      r => r.emailAddress?.address\n    );\n\n  // sent or received\n  const direction =\n    senderEmail?.toLowerCase() === MY_EMAIL\n      ? 'sent'\n      : 'received';\n\n  // body (HTML â text)\n  const message =\n    msg.body?.contentType === 'html'\n      ? stripHtml(msg.body.content)\n      : msg.body?.content || msg.bodyPreview || '';\n\n  return {\n    json: {\n      sheet_id,\n      message,                 // â plain text body\n      senderEmail,\n      receiverEmails,\n      direction,               // â sent | received\n      timestamp:\n        msg.sentDateTime || msg.receivedDateTime,\n      subject: msg.subject || null,\n      hasAttachments: msg.hasAttachments || false\n    },\n\n    // â keep binary data if Outlook node adds it later\n    binary: $input.all()[index]?.binary || {}\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        592,
        480
      ],
      "id": "b87c65b7-0b80-474e-b49f-ae121e1d7215",
      "name": "Normalize | Extract Message Metadata"
    },
