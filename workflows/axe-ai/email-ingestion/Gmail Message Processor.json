    {
      "parameters": {
        "jsCode": "const output = [];\n/**\n\u00c2\u00a0* Clean unwanted characters and normalize spacing\n\u00c2\u00a0*/\nconst cleanText = (text = \"\") =>\n\u00c2\u00a0\u00c2\u00a0text\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0.replace(/[<>&*]/g, \"\")\u00c2\u00a0\u00c2\u00a0 // remove special chars\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0.replace(/\\s+/g, \" \")\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0 // normalize spaces\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0.trim();\n\n/**\n\u00c2\u00a0* Remove everything AFTER an email inside <>\n\u00c2\u00a0* Example stop point: <example@gmail.com>\n\u00c2\u00a0*/\nconst cutAfterAngleEmail = (text = \"\") => {\n\u00c2\u00a0\u00c2\u00a0if (!text) return null;\n\n\u00c2\u00a0\u00c2\u00a0// Match <email@domain>\n\u00c2\u00a0\u00c2\u00a0const angleEmailRegex = /<[^>\\s]+@[^>\\s]+>/i;\n\n\u00c2\u00a0\u00c2\u00a0const match = text.match(angleEmailRegex);\n\u00c2\u00a0\u00c2\u00a0if (!match) return text;\n\n\u00c2\u00a0\u00c2\u00a0return text.slice(0, match.index);\n};\n\n/**\n\u00c2\u00a0* Extract ONLY reply content (remove quoted Gmail reply)\n\u00c2\u00a0*/\nconst extractReplyText = (text = \"\") => {\n\u00c2\u00a0\u00c2\u00a0if (!text) return null;\n\n\u00c2\u00a0\u00c2\u00a0// First: remove quoted reply block\n\u00c2\u00a0\u00c2\u00a0const splitPatterns = [\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\"\\nOn \",\u00c2\u00a0\u00c2\u00a0 // Gmail reply marker\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\"\\n>\"\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0 // quoted lines\n\u00c2\u00a0\u00c2\u00a0];\n\n\u00c2\u00a0\u00c2\u00a0let clean = text;\n\u00c2\u00a0\u00c2\u00a0for (const p of splitPatterns) {\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0if (clean.includes(p)) {\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0clean = clean.split(p)[0];\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0break;\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0}\n\u00c2\u00a0\u00c2\u00a0}\n\n\u00c2\u00a0\u00c2\u00a0// Second: cut after <email@domain>\n\u00c2\u00a0\u00c2\u00a0clean = cutAfterAngleEmail(clean);\n\n\u00c2\u00a0\u00c2\u00a0return cleanText(clean);\n};\n\n/**\n\u00c2\u00a0* MAIN LOOP\n\u00c2\u00a0*/\nfor (const input of items) {\n\u00c2\u00a0\u00c2\u00a0const e = input.json;\n\u00c2\u00a0\u00c2\u00a0const headers = e.headers || {};\n\n\u00c2\u00a0\u00c2\u00a0const isSent = e.labelIds?.includes(\"SENT\");\n\u00c2\u00a0\u00c2\u00a0const isReply =\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0!!e.inReplyTo ||\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0!!headers[\"in-reply-to\"] ||\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0!!headers.references;\n\n\u00c2\u00a0\u00c2\u00a0const rawText = e.text || \"\";\n\n\u00c2\u00a0\u00c2\u00a0const finalText = isReply\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0? extractReplyText(rawText)\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0: cleanText(cutAfterAngleEmail(rawText));\n\n\u00c2\u00a0\u00c2\u00a0output.push({\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0json: {\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0// Direction\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0direction: isSent ? \"SENT\" : \"RECEIVED\",\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0sheet_id:$('Loop | Gmail Message IDs').item.json.sheet_id,\n\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0// From\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0fromEmail: e.from?.value?.[0]?.address || null,\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0fromName: e.from?.value?.[0]?.name || null,\n\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0// To\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0toEmail: e.to?.value?.[0]?.address || null,\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0toName: e.to?.value?.[0]?.name || null,\n\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0// Subject\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0subject:\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0e.subject ||\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0headers.subject?.replace(\"Subject: \", \"\") ||\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0null,\n\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0// Timestamp\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0timestamp: e.date || null,\n\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0//  Cleaned message\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0message: finalText || null,\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0},\n\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0//  Preserve attachments exactly\n\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0\u00c2\u00a0binary: input.binary ?? undefined,\n\u00c2\u00a0\u00c2\u00a0});\n}\n\nreturn output;"
      },
