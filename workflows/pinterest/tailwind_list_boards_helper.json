        "method": "GET",
        "url": "https://api-v1.tailwind.ai/v1/accounts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "id": "n-accts",
      "name": "List Accounts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        560,
        200
      ],
      "credentials": {
        "httpBearerAuth": {
          "id": "TAILWIND_CRED_ID",
          "name": "Tailwind App"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let resp = $json;\nconst obj = Array.isArray(resp) ? (resp[0] || {}) : resp;\nlet accts = [];\nif (obj.data && Array.isArray(obj.data.accounts)) accts = obj.data.accounts;\nelse if (Array.isArray(obj.accounts)) accts = obj.accounts;\nelse if (obj.data && Array.isArray(obj.data)) accts = obj.data;\nelse if (Array.isArray(obj)) accts = obj;\nreturn accts.map(a => ({ json: {\n  accountId: a.id || a.accountId || a.account_id,\n  accountName: (a.username || a.displayName || a.name || '').toString().trim()\n} }));\n"
      },
      "id": "n-split",
      "name": "Split Accounts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        760,
        200
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api-v1.tailwind.ai/v1/accounts/{{ $json.accountId }}/boards",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "id": "n-boards",
      "name": "List Boards",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        960,
        200
      ],
      "credentials": {
        "httpBearerAuth": {
          "id": "TAILWIND_CRED_ID",
          "name": "Tailwind App"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let resp = $json;\nconst obj = Array.isArray(resp) ? (resp[0] || {}) : resp;\nconst acct = $('Split Accounts').item.json;\nlet boards = [];\nif (obj.data && Array.isArray(obj.data.boards)) boards = obj.data.boards;\nelse if (Array.isArray(obj.boards)) boards = obj.boards;\nelse if (obj.data && Array.isArray(obj.data)) boards = obj.data;\nelse if (Array.isArray(obj)) boards = obj;\nreturn boards.map(b => ({ json: {\n  'Pinterest Account': acct.accountName,\n  'Board Name': b.name || b.title || '',\n  'Board ID': (b.id || b.boardId || b.board_id || '').toString()\n} }));\n"
      },
