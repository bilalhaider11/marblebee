      "id": "5a9abffa-dbaf-4749-9ece-61a5ad986480",
      "name": "Get Pins",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1792,
        112
      ],
      "executeOnce": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "rKfNzy77xzsMahH6",
          "name": "Template_control"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const pins1 = $('Get Pins').all().map(i => ({ ...i.json, _sourceTab: $('Set Config').first().json.pinsTab }));\nconst pins2 = $('Get Pins 2').all().map(i => ({ ...i.json, _sourceTab: $('Set Config').first().json.pinsTab2 }));\nconst pins = [...pins1, ...pins2];\nfunction norm(s){ return (s==null?'':String(s)).trim().toLowerCase(); }\nconst out = [];\nfor (const p of pins) {\n  if (norm(p['Status']) !== 'scheduled') continue;\n  const postId = (p['Tailwind Post ID']==null?'':String(p['Tailwind Post ID'])).trim();\n  if (!postId) continue;\n  out.push({ json: { rowPinId: p['Pin ID'], postId, row_number: p['row_number'], sourceTab: p._sourceTab, retryCount: parseInt(p['Retry Count'], 10) || 0 } });\n}\nreturn out;\n"
      },
      "id": "3c90ff26-8193-4ca3-acd5-39cde2126587",
      "name": "Select Scheduled",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2176,
        112
      ]
    },
    {
      "parameters": {
        "url": "=https://api-v1.tailwind.ai/v1/accounts/{{ $('Set Config').first().json.accountId }}/posts/{{ $json.postId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "id": "8aa0f7c5-90f5-4dc9-a52f-80e0b653eb83",
      "name": "Get Post",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2400,
        112
      ],
      "credentials": {
        "httpBearerAuth": {
          "id": "04bNNmDkPyRmwKce",
          "name": "Tailwind App"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const responses = $input.all();\nconst sel = $('Select Scheduled').all();\nconst cfg = $('Set Config').first().json;\nconst maxRetries = cfg.maxRetries || 3;\nconst retryHours = (cfg.retryHours || '9,10').split(',').map(h => parseInt(h.trim(), 10)).filter(h => !isNaN(h)).sort((a, b) => a - b);\n\nfunction nextRetrySlot() {\n  const nowPlus15 = $now.plus({ minutes: 15 });\n  for (const h of retryHours) {\n    const slot = $now.set({ hour: h, minute: 0, second: 0, millisecond: 0 });\n    if (slot > nowPlus15) return slot;\n  }\n  // none of today's configured hours are far enough out -- use the earliest one tomorrow\n  return $now.plus({ days: 1 }).set({ hour: retryHours[0], minute: 0, second: 0, millisecond: 0 });\n}\n\nfunction pick(r){ const o = Array.isArray(r)?(r[0]||{}):r; return (o && o.data && (o.data.post || o.data)) || (o && o.post) || o || {}; }\nfunction toIso(ts){ if(ts==null||ts==='') return ''; let n=Number(ts); if(isNaN(n)) return ''; if(n < 1e12) n=n*1000; const dt=DateTime.fromMillis(n).toUTC(); return dt.isValid ? dt.toFormat(\"yyyy-LL-dd'T'HH:mm:ss'Z'\") : ''; }\n\nconst out = [];\nfor (let i=0;i<responses.length;i++){\n  const post = pick(responses[i].json || {});\n  const rowPinId = (sel[i] && sel[i].json.rowPinId) || '';\n  const rowNumber = (sel[i] && sel[i].json.row_number);\n  const sourceTab = (sel[i] && sel[i].json.sourceTab);\n  const retryCount = (sel[i] && sel[i].json.retryCount) || 0;\n  const postId = (sel[i] && sel[i].json.postId) || '';\n  if (!rowPinId) continue;\n  const status = (post.status||'').toString().toLowerCase();\n  const pinId = post.pinId || '';\n\n  if (pinId && (status === 'sent' || status === '')) {\n    out.push({ json: {\n      'row_number': rowNumber,\n      '_sourceTab': sourceTab,\n      'Pin ID': rowPinId,\n      'Status': 'Published',\n      'Pin URL': 'https://www.pinterest.com/pin/' + pinId + '/',\n      'Pinned Time': toIso(post.sentAt) || toIso(post.sendAt),\n      'Error': '',\n      'Tailwind Post ID': postId,\n      'Retry Count': retryCount,\n      'Scheduled Date': ''\n    } });\n  } else if (status === 'failed') {\n    const reason = String(post.failureReason || post.error || post.reason || 'Tailwind reported this post as failed');\n    const newRetryCount = retryCount + 1;\n    if (newRetryCount <= maxRetries) {\n      // Auto-retry: hand it back to WF2 as a fresh Review row, with the stale Tailwind\n      // Post ID cleared and a new near-future Scheduled Date (otherwise WF2 would\n      // immediately reject it again for having a past-due schedule instead of actually\n      // retrying it).\n      out.push({ json: {\n        'row_number': rowNumber,\n        '_sourceTab': sourceTab,\n        'Pin ID': rowPinId,\n        'Status': 'Review',\n        'Pin URL': '',\n        'Pinned Time': '',\n        'Tailwind Post ID': '',\n        'Retry Count': newRetryCount,\n        'Scheduled Date': nextRetrySlot().toFormat('yyyy-LL-dd HH:mm'),\n        'Error': reason.slice(0, 250) + ' (retry ' + newRetryCount + '/' + maxRetries + ')'\n      } });\n    } else {\n      // Exhausted retries -- leave it as a terminal error for manual review\n      out.push({ json: {\n        'row_number': rowNumber,\n        '_sourceTab': sourceTab,\n        'Pin ID': rowPinId,\n        'Status': 'Error',\n        'Pin URL': '',\n        'Pinned Time': '',\n        'Tailwind Post ID': '',\n        'Retry Count': newRetryCount,\n        'Scheduled Date': '',\n        'Error': reason.slice(0, 250) + ' (gave up after ' + maxRetries + ' retries)'\n      } });\n    }\n  }\n  // any other status (queued, processing, etc.) is still pending -- skip, checked again next run\n}\nreturn out;\n"
      },
