      "id": "fc0a3e11-befa-4fe2-b0ee-b31eda2ea49b",
      "name": "AI Vision Copy",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        42256,
        9184
      ],
      "credentials": {
        "openAiApi": {
          "id": "2A9snppPp3TR9vjL",
          "name": "OpenAi"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiItems = $input.all();\nconst pins = $('Split Pins').all();\nfunction preview(u){ return u ? '=IMAGE(\"' + u + '\", 4, 90, 90)' : ''; }\nconst out = [];\nfor (let i = 0; i < aiItems.length; i++) {\n  const pin = pins[i].json;\n  let ai = {};\n  const resp = aiItems[i].json;\n  let contentStr = resp.content || resp.text || (resp.message && resp.message.content) || '';\n  if (!contentStr && resp.choices && resp.choices[0] && resp.choices[0].message) contentStr = resp.choices[0].message.content || '';\n  contentStr = String(contentStr).replace(/```json/gi, '').replace(/```/g, '').trim();\n  try { ai = JSON.parse(contentStr); } catch (e) { ai = {}; }\n  const imgs = pin.images || [];\n\n  const candidateBoards = pin.candidateBoards || [];\n  let board = '', boardId = '';\n  if (candidateBoards.length === 1) {\n    board = candidateBoards[0].name;\n    boardId = candidateBoards[0].id;\n  } else if (candidateBoards.length > 1) {\n    const aiChoice = String(ai.board || '').trim().toLowerCase();\n    const matched = candidateBoards.find(b => b.name.trim().toLowerCase() === aiChoice);\n    const chosen = matched || candidateBoards[0];\n    board = chosen.name;\n    boardId = chosen.id;\n  }\n\n  out.push({ json: {\n    'Pin ID': pin.blogNo + '-P' + pin.pinIndex,\n    'Blog No.': pin.blogNo,\n    'Blog Title': pin.blogTitle,\n    'Pin Type': pin.type,\n    'Preview 1': preview(imgs[0]),\n    'Preview 2': preview(imgs[1]),\n    'Preview 3': preview(imgs[2]),\n    'Image 1 URL': imgs[0] || '',\n    'Image 2 URL': imgs[1] || '',\n    'Image 3 URL': imgs[2] || '',\n    'Pin Title': ai.title || '',\n    'Pin Description': ai.description || '',\n    'Alt Text': ai.alt || '',\n    'Blog Link': pin.blogUrl,\n    'Board': board,\n    'Board ID': boardId,\n    'Scheduled Date': pin.scheduledDate,\n    'Approval': 'Approved',\n    'Status': 'Review',\n    'Pin URL': '',\n    'Error': '',\n    'Created Time': $now.toISO(),\n    'Pinned Time': ''\n  } });\n}\nreturn out;\n"
      },
